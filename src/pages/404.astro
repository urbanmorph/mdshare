---
import Layout from "../layouts/Layout.astro";

export const prerender = true;
---

<Layout
  title="Not found — mdshare"
  description="The page or document you're looking for doesn't exist or has expired."
>
  <main class="flex-1 flex items-center justify-center p-4 sm:p-8">
    <div class="text-center max-w-md">
      <h1 class="text-6xl font-bold text-white mb-2">404</h1>
      <p class="text-lg text-neutral-300 mb-6">Not found</p>
      <p class="text-sm text-neutral-500 mb-8">
        The page or document you're looking for doesn't exist, the link is invalid,
        or the document has expired.
      </p>
      <a
        href="/"
        class="inline-block px-5 py-2.5 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-medium rounded-lg transition-colors"
      >
        Go to mdshare
      </a>
    </div>
  </main>
</Layout>
