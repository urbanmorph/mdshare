---
interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  canonical?: string;
  lang?: string;
  ogLocale?: string;
  fontHref?: string;
  ogImage?: string;
}

const {
  title = "mdshare — Share markdown with AI, free",
  description = "Share markdown files with Claude, ChatGPT, Cursor, and Windsurf via MCP. Upload, get a shareable link, collaborate in real-time. No login, no accounts, no cost.",
  ogType = "website",
  canonical,
  lang = "en",
  ogLocale = "en_US",
  fontHref,
} = Astro.props;

const siteUrl = "https://mdshare.live";
const ogImage = Astro.props.ogImage ?? `${siteUrl}/og.png`;
---

<!doctype html>
<html lang={lang} class="h-full antialiased dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0a0a0a" />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <link rel="icon" type="image/png" sizes="48x48" href="/favicon-48.png" />
    <link rel="icon" type="image/png" sizes="192x192" href="/favicon-192.png" />
    <link rel="icon" type="image/png" sizes="512x512" href="/favicon-512.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />

    <title>{title}</title>
    <meta name="description" content={description} />
    {canonical && <link rel="canonical" href={canonical} />}

    <!-- Open Graph -->
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:site_name" content="mdshare" />
    <meta property="og:type" content={ogType} />
    <meta property="og:url" content={canonical ?? siteUrl} />
    <meta property="og:locale" content={ogLocale} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={title} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Geist:wght@100..900&family=Geist+Mono:wght@100..900&display=swap"
      rel="stylesheet"
    />
    {/* Per-doc script font (RTL/CJK/Cyrillic/etc.) — only foreign docs load one. */}
    {fontHref && <link href={fontHref} rel="stylesheet" />}

    <!-- JSON-LD -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@graph": [
        {
          "@type": "Organization",
          "@id": `${siteUrl}/#organization`,
          "name": "mdshare",
          "url": siteUrl,
          "logo": `${siteUrl}/logo.svg`,
          "sameAs": [
            "https://github.com/urbanmorph/mdshare",
            "https://www.npmjs.com/package/mdshare-mcp",
            "https://glama.ai/mcp/servers/urbanmorph/mdshare",
            "https://cursor.directory/plugins/mdshare",
            "https://community.obsidian.md/plugins/mdshare"
          ]
        },
        {
          "@type": "WebSite",
          "@id": `${siteUrl}/#website`,
          "name": "mdshare",
          "alternateName": ["md share", "mdshare.live"],
          "url": siteUrl,
          "publisher": { "@id": `${siteUrl}/#organization` }
        },
        {
          "@type": "WebApplication",
          "name": "mdshare",
          "url": siteUrl,
          "description": "Free markdown sharing with MCP integration. Upload, get a link, collaborate. Works with Claude, ChatGPT, Gemini, Cursor, Windsurf.",
          "applicationCategory": "Productivity",
          "operatingSystem": "Any",
          "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
          "publisher": { "@id": `${siteUrl}/#organization` },
          "keywords": "markdown, sharing, MCP, model context protocol, collaboration, free, VS Code, Obsidian, link revocation, real-time, WebSocket"
        }
      ]
    })} />
  </head>
  <body class="min-h-full flex flex-col bg-neutral-950 text-neutral-200" style="font-family: 'Geist', 'Noto Sans', 'Noto Naskh Arabic', 'Noto Sans Hebrew', 'Noto Sans SC', 'Noto Sans JP', 'Noto Sans KR', 'Noto Sans Devanagari', 'Noto Sans Thai', system-ui, sans-serif;">
    <slot />
    <!-- Cloudflare Web Analytics. Auto-install is set in the dashboard but
         doesn't inject for Worker-served responses — this tag is the path. -->
    <script defer src="https://static.cloudflareinsights.com/beacon.min.js" data-cf-beacon='{"token": "360b73a366584eed8f0cf229f7f4d4a1"}'></script>
  </body>
</html>

<style is:global>
  @import "../styles/globals.css";

  code, pre, .font-mono, kbd {
    font-family: 'Geist Mono', monospace;
  }
</style>
